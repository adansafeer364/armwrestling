# ----------------------------------------------------------------------------
# Copy to .env.local for local dev, and set the same keys in Vercel → Project →
# Settings → Environment Variables for production.
# ----------------------------------------------------------------------------

# Auth (NextAuth). NEXTAUTH_URL must be your real deployed URL in production.
NEXTAUTH_URL="http://localhost:3000"
# Generate a strong secret: `openssl rand -hex 32`
NEXTAUTH_SECRET="change-me-to-a-long-random-string"

# MongoDB connection string (MongoDB Atlas recommended for Vercel).
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/armwrestling?appName=Cluster0"

# Cloudinary — REQUIRED for the public registration form (photo + payment uploads).
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Email (optional). If unset, approval/rejection emails are logged to the server
# console instead of sent. Set these to send real emails.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Armwrestling League <no-reply@yourdomain.com>"

# Floating WhatsApp contact button (country code, no + or spaces).
NEXT_PUBLIC_WHATSAPP_NUMBER="923278625085"
